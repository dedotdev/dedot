{
  "name": "@dedot/api",
  "version": "1.2.0",
  "description": "A delightful JavaScript/TypeScript client for Polkadot & Substrate",
  "author": "Thang X. Vu <thang@dedot.dev>",
  "homepage": "https://dedot.dev",
  "repository": {
    "directory": "packages/api",
    "type": "git",
    "url": "https://github.com/dedotdev/dedot.git"
  },
  "main": "src/index.ts",
  "type": "module",
  "sideEffects": false,
  "dependencies": {
    "@dedot/codecs": "^1.2.0",
    "@dedot/providers": "^1.2.0",
    "@dedot/runtime-specs": "^1.2.0",
    "@dedot/shape": "^1.2.0",
    "@dedot/storage": "^1.2.0",
    "@dedot/types": "^1.2.0",
    "@dedot/utils": "^1.2.0"
  },
  "scripts": {
    "build": "tsc --project tsconfig.build.json && tsc --project tsconfig.build.cjs.json",
    "clean": "rm -rf ./dist && rm -rf ./tsconfig.tsbuildinfo ./tsconfig.build.tsbuildinfo",
    "test": "npx vitest --watch=false"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./chaintypes": {
      "types": "./src/chaintypes/index.ts",
      "import": "./src/chaintypes/index.ts",
      "default": "./src/chaintypes/index.ts"
    }
  },
  "publishConfig": {
    "access": "public",
    "directory": "dist"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "Apache-2.0",
  "gitHead": "7993a90491771e8e2b726519c3e0e471e9eb2af5"
}
