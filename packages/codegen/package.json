{
  "name": "@dedot/codegen",
  "version": "1.2.0",
  "description": "Generate types",
  "author": "Thang X. Vu <thang@dedot.dev>",
  "homepage": "https://dedot.dev",
  "repository": {
    "directory": "packages/codegen",
    "type": "git",
    "url": "https://github.com/dedotdev/dedot.git"
  },
  "main": "src/index.ts",
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "build": "tsc --project tsconfig.build.json && tsc --project tsconfig.build.cjs.json && yarn copy",
    "test": "npx vitest --watch=false",
    "clean": "rm -rf ./dist && rm -rf ./tsconfig.tsbuildinfo ./tsconfig.build.tsbuildinfo",
    "copy": "cp -R ./src/chaintypes/templates ./dist/chaintypes && cp -R ./src/chaintypes/templates ./dist/cjs/chaintypes && cp -R ./src/typink/templates ./dist/typink && cp -R ./src/typink/templates ./dist/cjs/typink && cp -R ./src/sol/templates ./dist/sol && cp -R ./src/sol/templates ./dist/cjs/sol"
  },
  "dependencies": {
    "@dedot/api": "^1.2.0",
    "@dedot/codecs": "^1.2.0",
    "@dedot/contracts": "^1.2.0",
    "@dedot/providers": "^1.2.0",
    "@dedot/runtime-specs": "^1.2.0",
    "@dedot/shape": "^1.2.0",
    "@dedot/types": "^1.2.0",
    "@dedot/utils": "^1.2.0",
    "handlebars": "^4.7.8",
    "prettier": "^3.7.4"
  },
  "publishConfig": {
    "access": "public",
    "directory": "dist"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "Apache-2.0",
  "gitHead": "7993a90491771e8e2b726519c3e0e471e9eb2af5"
}
